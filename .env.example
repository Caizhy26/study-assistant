# Frontend: leave empty when backend and frontend share the same origin.
# If your frontend and backend are deployed separately, point this to your backend base URL.
VITE_API_BASE_URL=

# Backend text model proxy
DEEPSEEK_API_KEY=sk-xxxxxxxx
TEXT_API_URL=https://api.deepseek.com/chat/completions
TEXT_MODEL=deepseek-chat

# Backend vision model proxy (optional)
VISION_API_KEY=
VISION_API_URL=https://api.scnet.cn/api/llm/v1/chat/completions
VISION_MODEL=MiniMax-M2.5

# Backend server
PORT=8787
CORS_ORIGIN=*
